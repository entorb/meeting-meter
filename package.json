{
  "name": "meeting-meter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.19.0 <23 || >=24.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "run": "run-s build preview",
    "test": "vitest --watch=false",
    "test-cov": "vitest --watch=false --coverage",
    "cy:run": "cypress run --e2e",
    "cy:open": "cypress open --e2e",
    "types": "vue-tsc --build",
    "lint": "eslint . --cache --fix --ignore-pattern .gitignore",
    "format": "biome check --write .",
    "spell": "cspell --cache --quiet \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\"",
    "spell-store": "cspell --cache --quiet --words-only --unique \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\" > cspell-unknown-words.txt",
    "check": "run-p format lint types spell test knip",
    "knip": "knip"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.0",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@quasar/vite-plugin": "^1.12.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cspell": "^10.0.1",
    "cypress": "^15.16.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "~10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "npm-run-all2": "^9.0.1",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  }
}
