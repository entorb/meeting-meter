{
  "name": "meeting-meter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.19.0 <23 || >=24.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "run": "run-s build preview",
    "test": "vitest --watch=false",
    "test-cov": "vitest --watch=false --coverage",
    "cy:run": "cypress run --e2e",
    "cy:open": "cypress open --e2e",
    "types": "vue-tsc --build",
    "lint": "eslint . --cache --fix --ignore-pattern .gitignore",
    "format": "biome format --write .",
    "spell": "cspell --cache --quiet \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\"",
    "spell-store": "cspell --cache --quiet --words-only --unique \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\" > cspell-unknown-words.txt",
    "check": "run-p format lint types spell test"
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@mdi/js": "^7.4.47",
    "@quasar/vite-plugin": "^1.11.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cspell": "^10.0.0",
    "cypress": "^15.14.0",
    "eslint": "^9.14.0",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "~10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.99.0",
    "start-server-and-test": "^3.0.2",
    "typescript": "~6.0.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
